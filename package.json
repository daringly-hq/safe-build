{
  "name": "safe-build",
  "version": "0.1.0",
  "description": "Drop-in security scaffold for AI-built Next.js and Supabase apps.",
  "type": "module",
  "license": "MIT",
  "author": "Safe Build contributors",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "safe-build": "./bin/safe-build.mjs"
  },
  "exports": {
    ".": "./src/index.ts",
    "./runtime": "./src/runtime/index.ts"
  },
  "scripts": {
    "check": "npm run typecheck && npm test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daringly-hq/safe-build.git"
  },
  "bugs": {
    "url": "https://github.com/daringly-hq/safe-build/issues"
  },
  "homepage": "https://github.com/daringly-hq/safe-build#readme",
  "keywords": [
    "ai",
    "appsec",
    "nextjs",
    "supabase",
    "security",
    "vibe-coding"
  ],
  "engines": {
    "node": ">=20.18.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "typescript": "5.6.3",
    "vitest": "^4.1.9"
  }
}
